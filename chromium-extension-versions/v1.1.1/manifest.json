{
  "name": "OpenBrowser",
  "description": "OpenBrowser Extension",
  "version": "1.1.1",
  "manifest_version": 3,
  "background": {
    "type": "module",
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "icon_neutral.png",
    "48": "icon_neutral.png",
    "128": "icon_neutral.png"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "OpenBrowser"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "windows",
    "sidePanel",
    "downloads",
    "declarativeNetRequest",
    "webNavigation",
    "identity"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "http://localhost/*",
    "https://localhost/*",
    "*://*.ts.net/*",
    "https://aistudio.google.com/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*",
    "https://lovable.dev/*",
    "https://antigravity.google/*",
    "https://github.com/*"
  ],
  "optional_host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://*.openai.azure.com/*",
    "https://bedrock-runtime.*.amazonaws.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": []
    }
  ]
}
