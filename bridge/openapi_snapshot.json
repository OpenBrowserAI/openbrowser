          "keep_language": {
            "default": true,
            "title": "Keep Language",
            "type": "boolean"
          },
          "max_chars": {
            "anyOf": [
              {
                "maximum": 200000.0,
                "minimum": 1.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Chars"
          },
          "preserve_code_blocks": {
            "default": true,
            "title": "Preserve Code Blocks",
            "type": "boolean"
          }
        },
        "title": "Constraints",
        "type": "object"
      },
      "Context7DocsRequest": {
        "properties": {
          "lane": {
            "default": "OB_OFFLINE",
            "description": "OpenBrowser lane identifier (OB_OFFLINE or OB_ONLINE_PULSE)",
            "title": "Lane",
            "type": "string"
          },
          "library_id": {
            "description": "Context7 library id, e.g. /octokit/octokit.js",
            "title": "Library Id",
            "type": "string"
          },
          "max_chars": {
            "default": 20000,
            "description": "Maximum characters to return",
            "title": "Max Chars",
            "type": "integer"
          },
          "topic": {
            "default": "",
            "description": "Topic focus (optional)",
            "title": "Topic",
            "type": "string"
          }
        },
        "required": ["library_id"],
        "title": "Context7DocsRequest",
        "type": "object"
      },
      "ContextPackRequest": {
        "properties": {
          "lane": {
            "description": "OpenBrowser lane identifier (e.g. OB_OFFLINE, OB_ONLINE_PULSE)",
            "title": "Lane",
            "type": "string"
          },
          "page_text": {
            "default": "",
            "description": "Visible page text or extracted content",
            "title": "Page Text",
            "type": "string"
