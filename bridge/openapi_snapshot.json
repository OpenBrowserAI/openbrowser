      "GitHubGetRequest": {
        "properties": {
          "lane": {
            "default": "OB_OFFLINE",
            "description": "OpenBrowser lane identifier (OB_OFFLINE or OB_ONLINE_PULSE)",
            "title": "Lane",
            "type": "string"
          },
          "max_chars": {
            "default": 20000,
            "description": "Maximum characters to return",
            "title": "Max Chars",
            "type": "integer"
          },
          "path": {
            "description": "GitHub REST path, e.g. /repos/octokit/octokit.js or /search/repositories",
            "title": "Path",
            "type": "string"
          },
          "query": {
            "additionalProperties": true,
            "description": "Query parameters",
            "title": "Query",
            "type": "object"
          }
        },
        "required": ["path"],
        "title": "GitHubGetRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "Lane": {
        "enum": ["OB_OFFLINE", "OB_ONLINE_PULSE"],
        "title": "Lane",
        "type": "string"
      },
      "Mode": {
        "enum": ["clarify", "structure", "compress", "persona", "safe_exec"],
        "title": "Mode",
        "type": "string"
      },
      "MutationInfo": {
        "additionalProperties": false,
        "properties": {
          "note": {
            "title": "Note",
            "type": "string"
