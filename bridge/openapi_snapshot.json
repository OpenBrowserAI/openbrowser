          },
          "ssot_scopes": {
            "description": "Allowlisted SSOT scopes under core/SOCAcore",
            "items": {
              "type": "string"
            },
            "title": "Ssot Scopes",
            "type": "array"
          },
          "tab_meta": {
            "additionalProperties": true,
            "description": "Tab metadata (url/title/tabId/etc.)",
            "title": "Tab Meta",
